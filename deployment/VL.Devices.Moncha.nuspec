<?xml version="1.0"?>

<package xmlns="http://schemas.microsoft.com/packaging/2011/10/nuspec.xsd">
  <metadata>
    <id>VL.Devices.Moncha</id>
    <version>0.0.5-alpha</version>
    <title>VL.Devices.Moncha</title>
    <authors>vvvv, colorsound</authors>
    <projectUrl>https://github.com/vvvv/VL.Devices.Moncha</projectUrl>
    <repository type="git" url="https://github.com/vvvv/VL.Devices.Moncha.git" />
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Nodes to control the Moncha laser DAC</description>
    <tags>VL, laser, dac</tags>
    <dependencies>
      <dependency id="VL.IO.TCP" version="0.7.0" />
    </dependencies>
    <license type="expression">LGPL-3.0-only</license>
    <icon>icon\nugeticon.png</icon>
    <readme>docs\README.md</readme>
  </metadata>
  <files>
    <file src="..\lib\**\FNet.dll" target="lib\" exclude="" />
	<file src="..\lib\**\FTD2XX.dll" target="lib\" exclude="" />
	<file src="..\lib\**\MessagePack.Annotations.dll" target="lib\" exclude="" />
	<file src="..\lib\**\MessagePack.dll" target="lib\" exclude="" />
	<file src="..\lib\**\MonchaCommonBase.dll" target="lib\" exclude="" />
	<file src="..\lib\**\MonchaMiddleware32.dll" target="lib\" exclude="" />
    <file src="..\lib\**\MonchaMiddleware32.exe" target="lib\" exclude="" />
	<file src="..\lib\**\MonchaMiddleware32.runtimeconfig.json" target="lib\" exclude="" />
	<file src="..\lib\**\ServiceWire.dll" target="lib\" exclude="" />
	<file src="..\lib\**\StclDevices.dll" target="lib\" exclude="" />
	<file src="..\lib\**\STCLSystemLib.dll" target="lib\" exclude="" />
	<file src="..\lib\**\Stride.Core.dll" target="lib\" exclude="" />
	<file src="..\lib\**\Stride.Core.Mathematics.dll" target="lib\" exclude="" />
	<file src="..\lib\**\VL.Core.dll" target="lib\" exclude="" />
	<file src="..\lib\**\VL.Devices.Moncha.dll" target="lib\" exclude="" />
	<file src="..\lib\**\VL.Serialization.MessagePack.dll" target="lib\" exclude="" />
    <file src="..\*.vl" target="" exclude="" />
    <file src="..\help\**" target="help\" exclude="" />
    <file src="nugeticon.png" target="icon\" />
    <file src="..\README.md" target="docs\" />
  </files>
</package>
